# -----------------------------------------------------------------------------
# Example environment configuration.
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
#   cp .env.example .env
# -----------------------------------------------------------------------------

# Full SQLAlchemy database URL (psycopg 3 driver).
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/insurance_claims

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Path to the application log file (relative to project root).
LOG_FILE=logs/app.log

# --- Authentication (optional) ---
# When AUTH_ENABLED=true, data endpoints require header:  X-API-Key: <API_KEY>
# (/health and the docs stay public). Disabled by default.
AUTH_ENABLED=false
API_KEY=change-me
